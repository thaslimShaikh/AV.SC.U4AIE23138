{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "node16",
    "target": "es2019",

    "moduleResolution": "node16",
    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,

    "types": ["node"],

    "sourceMap": true
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}